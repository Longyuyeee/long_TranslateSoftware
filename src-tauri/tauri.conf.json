{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "胧翻译",
  "version": "0.2.1",
  "identifier": "com.ai.trans.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "胧翻译 · 智能助手",
        "width": 1000,
        "height": 700,
        "visible": false,
        "resizable": true
      },
      {
        "label": "floating",
        "title": "AI Translation",
        "width": 400,
        "height": 280,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": true
      },
      {
        "label": "ocr-overlay",
        "title": "OCR Selection",
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      }
    }
  }
}
